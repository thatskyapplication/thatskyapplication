{
	"name": "@thatskyapplication/notifications",
	"private": true,
	"type": "module",
	"files": [
		"distribution"
	],
	"scripts": {
		"build": "tsc",
		"test": "tsc --noEmit",
		"format": "biome check --write",
		"lint": "biome check",
		"dev": "tsx --env-file=.env.development source/index.ts | pino-pretty",
		"start": "node --import ./distribution/sentry.js distribution/index.js"
	},
	"dependencies": {
		"@discordjs/core": "dev",
		"@discordjs/rest": "dev",
		"@sentry/node": "^10.56.0",
		"@thatskyapplication/utility": "workspace:^",
		"croner": "^9.1.0",
		"i18next": "^25.10.10",
		"kysely": "^0.28.17",
		"pg": "^8.21.0",
		"pino": "^10.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/node": "^26.1.1",
		"@types/pg": "^8.20.0",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
