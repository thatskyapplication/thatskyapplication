{
	"name": "@thatskyapplication/caelus",
	"private": true,
	"type": "module",
	"files": [
		"distribution"
	],
	"scripts": {
		"build": "tsc",
		"test": "tsc --noEmit",
		"format": "biome check --write",
		"lint": "biome check",
		"dev": "tsx --env-file=.env.development source/index.ts | pino-pretty",
		"start": "node --import ./distribution/sentry.js distribution/index.js",
		"deploy-commands-dev": "tsx --env-file=.env.development source/utility/deploy-commands.ts | pino-pretty",
		"deploy-commands": "tsx source/utility/deploy-commands.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1061.0",
		"@discordjs/collection": "^2.1.1",
		"@discordjs/core": "dev",
		"@discordjs/rest": "dev",
		"@discordjs/ws": "dev",
		"@hono/node-server": "^1.19.14",
		"@sapphire/snowflake": "^3.5.5",
		"@sentry/node": "^10.56.0",
		"@thatskyapplication/utility": "workspace:^",
		"croner": "^9.1.0",
		"diff": "^8.0.4",
		"hono": "^4.12.23",
		"i18next": "^25.10.10",
		"kysely": "^0.28.17",
		"p-queue": "^9.3.0",
		"pg": "^8.21.0",
		"pino": "^10.3.0",
		"sharp": "^0.35.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@actions/core": "^2.0.2",
		"@biomejs/biome": "2.3.11",
		"@types/node": "^26.1.1",
		"@types/pg": "^8.20.0",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
