{
	"name": "@thatskyapplication/thatskyapplication",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "pnpm --recursive build",
		"test": "pnpm --recursive test",
		"lint": "pnpm --recursive lint",
		"format": "pnpm --recursive format",
		"update": "pnpm update --interactive --latest --recursive && pre-commit autoupdate",
		"knip": "knip"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"knip": "^5.88.1",
		"typescript": "^6.0.3"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "26",
			"onFail": "error"
		},
		"packageManager": {
			"name": "pnpm",
			"version": "11.9.0",
			"onFail": "error"
		}
	}
}
